{
  "schema_version": 1,
  "model": {
    "vocab_size": 8192,
    "max_seq_len": 4096,
    "num_layer": 12,
    "num_head": 8,
    "dim": 1024,
    "dim_key": 128,
    "dim_value": 128,
    "dim_ff_hidden": 4096,
    "use_rope": true,
    "ff_activation": "relu"
  },
  "tokenizer": "data/tokenizer.json",
  "data": {
    "train_path": "data/climbmix_small/shards_0_7.train.parquet",
    "validation_path": "data/climbmix_small/shards_0_7.val.parquet",
    "start_index": 0,
    "start_offset": 0,
    "add_sot": false,
    "add_eot": false
  },
  "train": {
    "steps": 5000,
    "seq_len": 256,
    "batch_size": 1024,
    "learning_rate": 0.0001,
    "weight_decay": 0.1,
    "micro_batches": 2,
    "log_period": 10,
    "checkpoint_interval": 100,
    "validation_batches": 300,
    "loop_dataset": true,
    "seed": 0,
    "use_bf16": true,
    "float32_precision": "high",
    "lr_schedule": {
      "type": "warmup_constant_cooldown",
      "warmup_steps": 200,
      "cooldown_steps": 500,
      "min_lr": 0.00001
    }
  }
}
